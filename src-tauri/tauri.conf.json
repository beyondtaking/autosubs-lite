{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoSubs Lite",
  "version": "0.1.1",
  "identifier": "com.autosubs.lite",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AutoSubs Lite",
        "width": 860,
        "height": 660,
        "minWidth": 600,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../python": "python"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
